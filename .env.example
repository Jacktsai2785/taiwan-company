# ── AI 引擎設定（全部在本機執行，不需 API Key）──────────────────────────────────
#
# 預設引擎：claude | codex | gemini | ollama（前端 ⚙ 可臨時切換覆寫）
AI_ENGINE=claude

# 本機 Claude CLI（預設引擎；不設路徑則自動偵測 PATH 上的 claude）
# CLAUDE_CLI_PATH=/usr/local/bin/claude
# CLAUDE_MODEL=

# OpenAI 官方 codex CLI（需先安裝並 codex login）
# CODEX_CLI_PATH=/usr/local/bin/codex
# CODEX_MODEL=

# Google 官方 gemini CLI（需先安裝並登入）
# GEMINI_CLI_PATH=/usr/local/bin/gemini
# GEMINI_MODEL=

# 開源模型 Ollama（OpenAI 相容端點；需先啟動 ollama 服務）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_VISION_MODEL=llava   # 處理圖片用；未設則圖片走本機 OCR 退路

# ── mops_investee 串接設定 ─────────────────────────────────────────────────────
# 反查公發公司持股的服務（mops_investee 專案）
MOPS_INVESTEE_URL=http://localhost:8080
MOPS_INVESTEE_API_KEY=your_api_key_here
