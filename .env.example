# ── Claude 設定（二擇一）────────────────────────────────────────────────────────
#
# 選項 A：Anthropic API（雲端部署必用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
#
# 選項 B：本機 Claude CLI（本地開發，不設 ANTHROPIC_API_KEY 則自動偵測）
# CLAUDE_CLI_PATH=C:\Users\user\.bun\install\cache\@anthropic-ai\claude-agent-sdk-win32-x64\0.2.117@@@1\claude.exe

# 使用的模型（可選，預設 claude-sonnet-4-6）
# CLAUDE_MODEL=claude-sonnet-4-6

# ── mops_investee 串接設定 ─────────────────────────────────────────────────────
# 反查公發公司持股的服務（mops_investee 專案）
MOPS_INVESTEE_URL=http://localhost:8080
MOPS_INVESTEE_API_KEY=your_api_key_here
